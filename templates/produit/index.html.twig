{% extends 'base.html.twig' %}

{% block title %}Liste des Produits{% endblock %}

{# On ajoute le CSS de DataTables juste pour cette page #}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    {# Ajout de Bootstrap Icons si tu ne l'as pas déjà dans ta base #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-dark">Gestion des Produits</h1>
        
        {# Seul le Magasinier (et l'Admin) peut créer un nouveau produit #}
        {% if is_granted('ROLE_MAGASINIER') %}
            <a href="{{ path('app_produit_new') }}" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Nouveau Produit
            </a>
        {% endif %}
    </div>

    {# Zone pour les messages flash de succès/erreur #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show shadow-sm border-0" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="table-produits" class="table table-hover align-middle w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-muted small text-uppercase fw-bold" style="width: 80px;">Visuel</th>
                            <th class="text-muted small text-uppercase fw-bold">Nom</th>
                            <th class="text-muted small text-uppercase fw-bold">Référence</th>
                            <th class="text-muted small text-uppercase fw-bold">Prix</th>
                            <th class="text-muted small text-uppercase fw-bold">Catégorie</th>
                            <th class="text-muted small text-uppercase fw-bold">Fournisseur</th>
                            <th class="text-muted small text-uppercase fw-bold text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for produit in produits %}
                        <tr>
                            <td>
                                {% if produit.imageName %}
                                    <img src="{{ asset('uploads/products/' ~ produit.imageName) }}" 
                                         alt="{{ produit.nom }}" 
                                         class="rounded shadow-sm border"
                                         style="width: 45px; height: 45px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center border" style="width: 45px; height: 45px;">
                                        <i class="bi bi-camera text-muted"></i>
                                    </div>
                                {% endif %}
                            </td>

                            <td>
                                <div class="fw-bold text-dark">{{ produit.nom }}</div>
                            </td>

                            <td><code class="text-primary small fw-bold">{{ produit.reference }}</code></td>

                            <td class="fw-semibold text-dark">{{ produit.prixVente|number_format(2, ',', ' ') }} €</td>

                            <td>
                                {% if produit.categorie %}
                                    <span class="badge bg-soft-info text-info border border-info border-opacity-25" style="background-color: #e0f2fe; color: #0369a1;">
                                        {{ produit.categorie.nom }}
                                    </span>
                                {% else %}
                                    <span class="text-muted small italic">Aucune</span>
                                {% endif %}
                            </td>

                            <td>
                                {% if produit.fournisseur %}
                                    <div class="small text-dark">
                                        <i class="bi bi-building text-muted me-1"></i>{{ produit.fournisseur.nom }}
                                    </div>
                                {% else %}
                                    <span class="text-muted small">N/A</span>
                                {% endif %}
                            </td>

                            <td class="text-end">
                                <div class="btn-group shadow-sm" role="group">
                                    {# Tout le monde peut voir les détails #}
                                    <a href="{{ path('app_produit_show', {'id': produit.id}) }}" class="btn btn-sm btn-white border" title="Détails">
                                        <i class="bi bi-eye text-primary"></i>
                                    </a>
                                    
                                    {# Sécurisation : Seuls Magasinier et Admin voient Modifier et Dupliquer #}
                                    {% if is_granted('ROLE_MAGASINIER') %}
                                        <a href="{{ path('app_produit_edit', {'id': produit.id}) }}" class="btn btn-sm btn-white border" title="Modifier">
                                            <i class="bi bi-pencil text-warning"></i>
                                        </a>
                                        
                                        <a href="{{ path('app_produit_clone', {'id': produit.id}) }}" class="btn btn-sm btn-white border text-dark" title="Dupliquer">
                                            <i class="bi bi-copy"></i>
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                            
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#table-produits').DataTable({
                language: {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json"
                },
                pageLength: 10,
                // CORRECTION : Trie par Nom (colonne 1) par ordre alphabétique (asc)
                order: [[1, 'asc']], 
                columnDefs: [
                    // CORRECTION : La colonne action est maintenant la numéro 6 (car l'ID a disparu)
                    { orderable: false, targets: [0, 6] } 
                ],
                drawCallback: function() {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });
        });
    </script>
{% endblock %}