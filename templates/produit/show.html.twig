{% extends 'base.html.twig' %}

{% block title %}Détails du Produit{% endblock %}

{% block body %}
    <div class="container mt-4">
        
        <div class="row">
            
            {# --- COLONNE GAUCHE : L'IMAGE & LE QR CODE --- #}
            <div class="col-md-4 text-center mb-4">
                
                {# 1. La carte de l'image du produit #}
                <div class="card shadow border-0 mb-3">
                    <div class="card-body">
                        {% if produit.imageName %}
                            <img src="{{ asset('uploads/products/' ~ produit.imageName) }}" 
                                 alt="{{ produit.nom }}" 
                                 class="img-fluid rounded" 
                                 style="max-height: 400px; object-fit: contain;">
                        {% else %}
                            <div class="alert alert-light py-5 text-muted">
                                <span style="font-size: 3rem;">📷</span><br>
                                Pas d'image disponible
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# 2. LE NOUVEAU WIDGET QR CODE #}
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body text-center p-4">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3">
                            <i class="bi bi-qr-code-scan text-primary me-2"></i>Scan Mobile
                        </h6>
                        
                        {# qr_code_data_uri() génère l'image instantanément #}
                        {# url() au lieu de path() génère le lien complet (http://...) pour le mobile #}
                        <img src="{{ qr_code_data_uri(url('app_produit_show', {'id': produit.id})) }}" 
                             alt="QR Code {{ produit.reference }}" 
                             class="img-thumbnail border-0 shadow-sm rounded-3 mb-2" 
                             style="width: 140px; height: 140px;">
                        
                        <div class="small text-muted mt-2">
                            Réf: <code class="fw-bold text-dark">{{ produit.reference }}</code>
                        </div>
                    </div>
                </div>

            </div>
            {# --- FIN COLONNE GAUCHE --- #}

            {# --- COLONNE DROITE : LES INFOS --- #}
            <div class="col-md-8">
                <h1 class="mb-3">{{ produit.nom }}</h1>
                
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-striped mb-0">
                            <tbody>
                                <tr>
                                    <th class="ps-3" style="width: 30%;">Id</th>
                                    <td>{{ produit.id }}</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Référence</th>
                                    <td><span class="badge bg-secondary">{{ produit.reference }}</span></td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Prix de Vente</th>
                                    <td class="fw-bold text-success">{{ produit.prixVente }} €</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Fournisseur</th>
                                    <td>
                                        {% if produit.fournisseur %}
                                            <a href="{{ path('app_fournisseur_show', {'id': produit.fournisseur.id}) }}" class="text-decoration-none">
                                                🏢 {{ produit.fournisseur.nom }}
                                            </a>
                                            <br>
                                            <small class="text-muted">{{ produit.fournisseur.email }}</small>
                                        {% else %}
                                            <span class="text-muted">Aucun fournisseur enregistré</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% if produit.seuilAlerte is defined %}
                                <tr>
                                    <th class="ps-3">Seuil d'alerte</th>
                                    <td class="text-danger fw-bold">{{ produit.seuilAlerte }} unités</td>
                                </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# --- BOUTONS D'ACTION SÉCURISÉS --- #}
                <div class="mt-4 d-flex gap-2">
                    {# Bouton Retour : visible par tous #}
                    <a href="{{ path('app_produit_index') }}" class="btn btn-secondary">
                        ← Retour à la liste
                    </a>
                    
                    {# Bouton Modifier : visible uniquement pour Magasinier et Admin #}
                    {% if is_granted('ROLE_MAGASINIER') %}
                        <a href="{{ path('app_produit_edit', {'id': produit.id}) }}" class="btn btn-warning">
                            ✏️ Modifier
                        </a>
                    {% endif %}

                    {# Formulaire de Suppression : visible uniquement pour l'Admin #}
                    {% if is_granted('ROLE_ADMIN') %}
                        {{ include('produit/_delete_form.html.twig') }}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}