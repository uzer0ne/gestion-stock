<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Gestion Stock{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        
        {# 1. LE STYLE (CSS) : On charge Bootstrap et les icônes depuis Internet #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        
        {# 2. TES STYLES PERSO (Si tu en as besoin plus tard) #}
        {% block stylesheets %}
        {% endblock %}
    </head>
    <body>
        {# --- NAVBAR (Menu du haut) --- #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">📦 Gestion Stock</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    {# Liens de navigation à gauche #}
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_produit_index') }}">Produits</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_categorie_index') }}">Catégories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_stock_index') }}">Gestion Stock</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_historique') }}">Historique</a>
                        </li>
                    </ul>

                    {# Section Authentification à droite #}
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        {% if app.user %}
                            {# Si l'utilisateur est connecté #}
                            <li class="nav-item">
                                <span class="text-white-50 small me-2">
                                    <i class="bi bi-person-circle me-1"></i>{{ app.user.userIdentifier }}
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                                </a>
                            </li>
                        {% else %}
                            {# Si l'utilisateur n'est pas connecté #}
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm text-primary fw-bold" href="{{ path('app_login') }}">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Connexion
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {# --- CORPS DE LA PAGE --- #}
        <div class="container">
            {% block body %}{% endblock %}
        </div>

        {# 3. LE MOTEUR (JS) : Pour que les menus déroulants fonctionnent #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        
        {% block javascripts %}
        {# 👇 C'EST CETTE LIGNE QUI MANQUAIT POUR CHART.JS 👇 #}
            {{ importmap('app') }}
        {% endblock %}
    </body>
</html>