{% extends 'base.html.twig' %}

{% block title %}Inscription - StockFlow{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-plus-fill fs-3"></i>
                        </div>
                        <h1 class="h3 fw-bold text-dark mb-2">Créer un compte</h1>
                        <p class="text-muted">Rejoignez l'espace de gestion StockFlow</p>
                    </div>

                    {# Affichage des erreurs éventuelles (ex: email déjà pris) #}
                    {{ form_errors(registrationForm) }}

                    {{ form_start(registrationForm) }}
                        <div class="mb-3">
                            {{ form_label(registrationForm.email, 'Adresse Email', {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form-control-lg bg-light', 'placeholder': 'nom@entreprise.com'}}) }}
                            {# 👇 AFFICHAGE DE L'ERREUR EMAIL 👇 #}
                            <div class="text-danger small mt-1 fw-bold">
                                {{ form_errors(registrationForm.email) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control form-control-lg bg-light', 'placeholder': '••••••••'}}) }}
                            {# 👇 AFFICHAGE DE L'ERREUR MOT DE PASSE 👇 #}
                            <div class="text-danger small mt-1 fw-bold">
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>
                            <div class="form-text text-muted small mt-1">Votre mot de passe doit contenir au moins 6 caractères.</div>
                        </div>

                        <div class="mb-4 form-check">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeTerms, 'J\'accepte les conditions d\'utilisation', {'label_attr': {'class': 'form-check-label text-muted small'}}) }}
                            {# 👇 AFFICHAGE DE L'ERREUR CHECKBOX 👇 #}
                            <div class="text-danger small mt-1 fw-bold">
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">
                                S'inscrire <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    {{ form_end(registrationForm) }}

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">
                            Vous avez déjà un compte ? <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">Se connecter</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}