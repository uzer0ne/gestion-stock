{% extends 'base.html.twig' %}

{% block title %}Connexion - StockFlow{% endblock %}

{% block body %}
<div class="container py-5 mb-5">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-6 col-lg-5">
            
            {# --- EN-TÊTE : Logo et Titre --- #}
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px;">
                    <i class="bi bi-box-seam fs-1"></i>
                </div>
                <h1 class="h3 fw-bold text-dark mb-1">Bienvenue sur StockFlow</h1>
                <p class="text-muted">Connectez-vous pour accéder à votre espace.</p>
            </div>

            {# --- CARTE DU FORMULAIRE --- #}
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <form method="post">
                        {# Gestion des erreurs (Mauvais mot de passe, etc.) #}
                        {% if error %}
                            <div class="alert alert-danger rounded-3 small">
                                <i class="bi bi-exclamation-circle-fill me-2"></i>
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        {# Message si on retourne sur la page de login alors qu'on est déjà connecté #}
                        {% if app.user %}
                            <div class="alert alert-info rounded-3 small">
                                Vous êtes déjà connecté(e) en tant que <strong>{{ app.user.userIdentifier }}</strong>. 
                                <br><a href="{{ path('app_logout') }}" class="alert-link">Se déconnecter</a>
                            </div>
                        {% else %}
                        
                            {# Champ Email avec label flottant #}
                            <div class="form-floating mb-3">
                                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control rounded-3" placeholder="name@example.com" autocomplete="email" required autofocus>
                                <label for="inputEmail" class="text-muted"><i class="bi bi-envelope me-2"></i>Adresse Email</label>
                            </div>

                            {# Champ Mot de passe avec label flottant #}
                            <div class="form-floating mb-4">
                                <input type="password" name="password" id="inputPassword" class="form-control rounded-3" placeholder="Mot de passe" autocomplete="current-password" required>
                                <label for="inputPassword" class="text-muted"><i class="bi bi-lock me-2"></i>Mot de passe</label>
                            </div>

                            {# Jeton de sécurité CSRF (invisible mais obligatoire) #}
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            {# Options supplémentaires (Se souvenir de moi & Oubli MDP) #}
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                    <label class="form-check-label small text-muted" for="rememberMe">Se souvenir de moi</label>
                                </div>
                            </div>

                            {# Bouton de validation #}
                            <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm" type="submit">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                            </button>
                            
                        {% endif %}
                    </form>
                </div>
            </div>
            
            {# --- PIED DE PAGE DISCRET --- #}
            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="bi bi-shield-lock me-1"></i> Accès sécurisé. &copy; {{ 'now'|date('Y') }}
                </p>
            </div>

        </div>
    </div>
</div>
{% endblock %}