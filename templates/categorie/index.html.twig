{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories{% endblock %}

{% block body %}
<div class="container py-5">

    {# En-tête avec bouton de création #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="h2 fw-bold mb-0 text-dark">Liste des Catégories</h1>
            <p class="text-muted mb-0">Organisez vos produits par secteurs d'activité.</p>
        </div>
        <a href="{{ path('app_categorie_new') }}" class="btn btn-primary shadow-sm px-4 py-2 rounded-pill">
            <i class="bi bi-plus-lg me-2"></i>Nouvelle catégorie
        </a>
    </div>

    {# Carte contenant le tableau #}
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold">
                    <tr>
                        <th class="ps-4 py-3 text-muted" style="width: 80px;">Id</th>
                        <th class="py-3">Nom de la catégorie</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for categorie in categories %}
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-dark border">#{{ categorie.id }}</span>
                        </td>
                        <td class="fw-semibold text-dark">
                            <i class="bi bi-tag-fill text-primary me-2"></i>{{ categorie.nom }}
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="btn btn-sm btn-outline-secondary" title="Voir les détails">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center py-5">
                            <div class="text-muted">
                                <i class="bi bi-folder-x display-4 d-block mb-3"></i>
                                <p class="mb-0">Aucun enregistrement trouvé.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    {# Petit récapitulatif en bas #}
    <div class="mt-3 text-end text-muted small">
        Total : <strong>{{ categories|length }}</strong> catégorie(s) enregistrée(s).
    </div>

</div>
{% endblock %}