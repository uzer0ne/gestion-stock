{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories{% endblock %}

{# On ajoute le CSS de DataTables #}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
{% endblock %}

{% block body %}
<div class="container py-5">

    {# En-tête avec bouton de création #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="h2 fw-bold mb-0 text-dark">Liste des Catégories</h1>
            <p class="text-muted mb-0">Organisez vos produits par secteurs d'activité.</p>
        </div>
        <a href="{{ path('app_categorie_new') }}" class="btn btn-primary shadow-sm px-4 py-2 rounded-pill">
            <i class="bi bi-plus-lg me-2"></i>Nouvelle catégorie
        </a>
    </div>

    {# Carte contenant le tableau #}
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="table-categories" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light text-uppercase small fw-bold">
                        <tr>
                            <th class="py-3 text-muted">Nom de la catégorie</th>
                            <th class="py-3 text-muted text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for categorie in categories %}
                        <tr>
                            <td class="fw-semibold text-dark">
                                <i class="bi bi-tag-fill text-primary me-2"></i>{{ categorie.nom }}
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm" role="group">
                                    <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="btn btn-sm btn-white border" title="Voir les détails">
                                        <i class="bi bi-eye text-primary"></i>
                                    </a>
                                    <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-sm btn-white border" title="Modifier">
                                        <i class="bi bi-pencil text-warning"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-folder-x display-4 d-block mb-3"></i>
                                    <p class="mb-0">Aucun enregistrement trouvé.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{# On initialise DataTables #}
{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#table-categories').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json'
                },
                pageLength: 10,
                // Tri alphabétique par défaut sur le Nom (qui est maintenant la colonne 0)
                order: [[0, 'asc']], 
                columnDefs: [
                    // Désactive le tri sur les boutons d'Actions (colonne 1)
                    { orderable: false, targets: 1 } 
                ],
                drawCallback: function() {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });
        });
    </script>
{% endblock %}