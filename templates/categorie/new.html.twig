{% extends 'base.html.twig' %}

{% block title %}Nouvelle Catégorie{% endblock %}

{% block body %}
<div class="container py-5">
    
    {# Fil d'ariane pour la navigation rapide #}
    <div class="row justify-content-center mb-4">
        <div class="col-lg-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a href="{{ path('app_categorie_index') }}">Catégories</a></li>
                    <li class="breadcrumb-item active">Création</li>
                </ol>
            </nav>
            <h1 class="h2 fw-bold text-dark">Ajouter une catégorie</h1>
            <p class="text-muted small">Créez un nouveau segment pour organiser vos futurs produits.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="card-title mb-0 fw-bold text-primary">
                        <i class="bi bi-plus-circle-fill me-2"></i>Nouvel enregistrement
                    </h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    {# Intégration du formulaire avec bouton stylisé #}
                    {{ include('categorie/_form.html.twig', {
                        'button_label': 'Enregistrer la catégorie',
                        'button_class': 'btn btn-primary btn-lg w-100 fw-bold shadow-sm'
                    }) }}

                    <div class="text-center mt-4">
                        <a href="{{ path('app_categorie_index') }}" class="text-decoration-none text-muted small">
                            <i class="bi bi-x-circle me-1"></i> Annuler et retourner à la liste
                        </a>
                    </div>
                </div>
            </div>

            {# Petit conseil UX pour le jury #}
            <div class="mt-4 p-3 bg-light rounded-3 border border-light text-center">
                <span class="text-muted small">
                    <i class="bi bi-info-circle me-2"></i>
                    Astuce : Utilisez des noms courts et explicites (ex: "Informatique", "Mobilier").
                </span>
            </div>
        </div>
    </div>
</div>
{% endblock %}