{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
    
    <div class="row g-4">
        {# Champ Nom de la catégorie #}
        <div class="col-12">
            {{ form_label(form.nom, 'Nom de la catégorie', {'label_attr': {'class': 'form-label fw-bold text-dark small text-uppercase'}}) }}
            
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-tag text-muted"></i>
                </span>
                {{ form_widget(form.nom, {
                    'attr': {
                        'class': 'form-control border-start-0 ps-0', 
                        'placeholder': 'Ex: Informatique, Mobilier, Consommables...'
                    }
                }) }}
            </div>
            
            <div class="form-text mt-2">
                <i class="bi bi-info-circle me-1"></i> 
                Ce nom sera utilisé pour filtrer vos produits dans les inventaires.
            </div>
            
            {# Affichage des erreurs de validation #}
            {% if form_errors(form.nom) %}
                <div class="alert alert-danger mt-2 py-2 small">
                    {{ form_errors(form.nom) }}
                </div>
            {% endif %}
        </div>

        {# Bouton de validation dynamique #}
        <div class="col-12 mt-4">
            <button class="{{ button_class|default('btn btn-primary btn-lg w-100 shadow-sm') }}">
                <i class="bi bi-check2-circle me-2"></i>
                {{ button_label|default('Enregistrer la catégorie') }}
            </button>
        </div>
    </div>

{{ form_end(form) }}