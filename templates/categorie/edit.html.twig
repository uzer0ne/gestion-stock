{% extends 'base.html.twig' %}

{% block title %}Modifier la catégorie : {{ categorie.nom }}{% endblock %}

{% block body %}
<div class="container py-5">

    {# En-tête avec navigation #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('app_categorie_index') }}">Catégories</a></li>
                    <li class="breadcrumb-item active text-truncate" style="max-width: 200px;">Édition #{{ categorie.id }}</li>
                </ol>
            </nav>
            <h1 class="h2 fw-bold mb-0 text-dark">Modifier la catégorie</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_categorie_index') }}" class="btn btn-light border shadow-sm">
                <i class="bi bi-arrow-left me-2"></i>Retour à la liste
            </a>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        {# Colonne du Formulaire #}
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="card-title mb-0 fw-bold text-primary">
                        <i class="bi bi-pencil-square me-2"></i>Informations de la catégorie
                    </h5>
                </div>
                <div class="card-body p-4">
                    {# On passe le style du bouton au formulaire #}
                    {{ include('categorie/_form.html.twig', {
                        'button_label': 'Mettre à jour la catégorie',
                        'button_class': 'btn btn-primary btn-lg w-100 fw-bold shadow-sm'
                    }) }}
                </div>
            </div>
        </div>

        {# Colonne Latérale : Actions Critiques #}
        <div class="col-lg-4">
            <div class="card border-danger shadow-sm rounded-3 bg-light bg-gradient h-100">
                <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                    <div class="mb-3">
                        <i class="bi bi-exclamation-triangle text-danger display-4"></i>
                    </div>
                    <h5 class="text-danger fw-bold mb-2">Zone de danger</h5>
                    <p class="small text-muted mb-4">
                        Attention : la suppression d'une catégorie peut affecter les produits qui y sont rattachés. Assurez-vous qu'aucun stock n'est lié avant de confirmer.
                    </p>
                    <div class="d-grid">
                        {{ include('categorie/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}