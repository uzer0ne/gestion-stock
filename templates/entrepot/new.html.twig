{% extends 'base.html.twig' %}

{% block title %}Nouvel Entrepôt{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="text-center mb-5">
                <div class="display-1 text-primary opacity-25 mb-3"><i class="bi bi-plus-square"></i></div>
                <h1 class="h2 fw-bold text-dark">Créer un nouveau site</h1>
                <p class="text-muted">Ajoutez un nouvel espace de stockage à votre réseau logistique.</p>
            </div>

            <div class="card border-0 shadow rounded-4">
                <div class="card-body p-4 p-md-5">
                    {{ include('entrepot/_form.html.twig', {'button_label': 'Créer l\'entrepôt'}) }}
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="{{ path('app_entrepot_index') }}" class="btn btn-link text-muted"><i class="bi bi-arrow-left me-2"></i>Retour à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}