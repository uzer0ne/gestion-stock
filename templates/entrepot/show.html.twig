{% extends 'base.html.twig' %}

{% block title %}Détails : {{ entrepot.nom }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1 small text-uppercase">
                    <li class="breadcrumb-item"><a href="{{ path('app_entrepot_index') }}">Entrepôts</a></li>
                    <li class="breadcrumb-item active">Fiche technique</li>
                </ol>
            </nav>
            <h1 class="h2 fw-bold text-dark m-0">{{ entrepot.nom }}</h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_entrepot_index') }}" class="btn btn-light border">
                <i class="bi bi-arrow-left"></i>
            </a>
            <a href="{{ path('app_entrepot_edit', {'id': entrepot.id}) }}" class="btn btn-primary shadow-sm px-4">
                <i class="bi bi-pencil-square me-2"></i>Modifier
            </a>
        </div>
    </div>

    <div class="row g-4">
        {# Infos générales #}
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-building-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">{{ entrepot.nom }}</h5>
                    <p class="text-muted mb-4"><i class="bi bi-geo-alt-fill me-1"></i>{{ entrepot.ville }}</p>
                    
                    <div class="bg-light p-3 rounded-3 text-start">
                        <div class="small text-muted text-uppercase fw-bold mb-1">Identifiant</div>
                        <div class="font-monospace">SITE-ID-{{ entrepot.id }}</div>
                    </div>
                </div>
            </div>
        </div>

        {# Liste des stocks dans cet entrepôt #}
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0 fw-bold">📦 Stocks sur ce site</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Produit</th>
                                    <th>Emplacement</th>
                                    <th class="text-end pe-4">Qté</th>
                                </tr>
                            </thead>
                            <tbody>
                            {# Supposant la relation 'stocks' dans l'entité Entrepot #}
                            {% for stock in entrepot.stocks %}
                                <tr>
                                    <td class="ps-4 fw-semibold">{{ stock.produit.nom }}</td>
                                    <td><span class="badge bg-light text-dark border">{{ stock.emplacement }}</span></td>
                                    <td class="text-end pe-4 fw-bold">{{ stock.quantite }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">Aucun stock répertorié pour ce site.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}