{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ entrepot.nom }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <h1 class="h2 fw-bold mb-0 text-dark">Paramètres du site</h1>
                <a href="{{ path('app_entrepot_index') }}" class="btn btn-link text-decoration-none text-muted">Annuler</a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 p-md-5">
                    {{ include('entrepot/_form.html.twig', {'button_label': 'Enregistrer les changements'}) }}
                </div>
            </div>

            <div class="bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-3 p-4 d-flex justify-content-between align-items-center">
                <div class="text-danger small fw-bold">
                    <i class="bi bi-exclamation-octagon me-2"></i>Zone critique
                </div>
                {{ include('entrepot/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}