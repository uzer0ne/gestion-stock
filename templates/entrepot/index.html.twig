{% extends 'base.html.twig' %}

{% block title %}Gestion des Entrepôts{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-0 text-dark">Liste des Entrepôts</h1>
            <p class="text-muted">Gérez vos différents sites de stockage et leur localisation.</p>
        </div>
        <a href="{{ path('app_entrepot_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Nouvel Entrepôt
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold">
                    <tr>
                        <th class="ps-4 py-3 text-muted" style="width: 80px;">Id</th>
                        <th class="py-3">Nom du site</th>
                        <th class="py-3">Ville / Localisation</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for entrepot in entrepots %}
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-dark border">#{{ entrepot.id }}</span>
                        </td>
                        <td class="fw-bold text-dark">
                            <i class="bi bi-building text-primary me-2"></i>{{ entrepot.nom }}
                        </td>
                        <td>
                            <span class="text-muted"><i class="bi bi-geo-alt me-1"></i>{{ entrepot.ville }}</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a href="{{ path('app_entrepot_show', {'id': entrepot.id}) }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_entrepot_edit', {'id': entrepot.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="text-muted">
                                <i class="bi bi-building-dash display-4 d-block mb-3"></i>
                                <p>Aucun entrepôt n'a encore été créé.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}