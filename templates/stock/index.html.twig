{% extends 'base.html.twig' %}

{% block title %}État des Stocks{% endblock %}

{# 1. ON AJOUTE LE CSS DE DATATABLES #}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-0">Gestion du Stock</h1>
            <p class="text-muted">Suivi des quantités et des emplacements en temps réel.</p>
        </div>
        <a href="{{ path('app_stock_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Ajouter du Stock
        </a>
    </div>

    {# Messages flash de confirmation #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show shadow-sm border-0" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table id="table-stocks" class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold text-muted">
                    <tr>
                        <th class="ps-4 py-3">Produit & Référence</th>
                        <th class="py-3 text-center">Emplacement</th>
                        <th class="py-3 text-center" style="width: 200px;">Quantité (Contrôle)</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stock in stocks %}
                    {% set estCritique = stock.quantite <= stock.produit.seuilAlerte %}
                    <tr class="{{ estCritique ? 'table-warning' : '' }}">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div>
                                    <div class="fw-bold text-dark">{{ stock.produit.nom }}</div>
                                    <small class="text-primary font-monospace">{{ stock.produit.reference }}</small>
                                </div>
                                {% if estCritique %}
                                    <span class="badge bg-danger ms-3 pulse-animation">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> STOCK BAS
                                    </span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border px-3 py-2">
                                <i class="bi bi-geo-alt-fill text-secondary me-1"></i>{{ stock.emplacement }}
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_stock_mouvement', {'id': stock.id, 'sens': 'moins'}) }}" 
                                   class="btn btn-sm btn-outline-danger px-3 fw-bold">-</a>
                                
                                {# BOUTON MODIFIÉ : Il ouvre maintenant la Modale #}
                                <button type="button" class="btn btn-sm fw-bold text-dark px-3" style="min-width: 50px; background: white; border-top: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6;" data-bs-toggle="modal" data-bs-target="#modalMasse{{ stock.id }}">
                                    {{ stock.quantite }} <i class="bi bi-box-seam ms-1 text-primary"></i>
                                </button>

                                <a href="{{ path('app_stock_mouvement', {'id': stock.id, 'sens': 'plus'}) }}" 
                                   class="btn btn-sm btn-outline-success px-3 fw-bold">+</a>
                            </div>

                            {# --- LA MODALE BOOTSTRAP DE MASSE --- #}
                            <div class="modal fade text-start" id="modalMasse{{ stock.id }}" tabindex="-1" aria-hidden="true">
                              <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                  <form action="{{ path('app_stock_mouvement_masse', {'id': stock.id}) }}" method="POST">
                                      <div class="modal-header bg-light">
                                        <h5 class="modal-title"><i class="bi bi-boxes me-2"></i>Mouvement de lot</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <div class="modal-body">
                                        <p>Produit : <strong>{{ stock.produit.nom }}</strong></p>
                                        <div class="mb-3">
                                            <label class="form-label">Quantité à traiter :</label>
                                            <input type="number" name="quantite" class="form-control form-control-lg" min="1" value="10" required>
                                        </div>
                                      </div>
                                      <div class="modal-footer justify-content-between">
                                        <button type="submit" name="action" value="retrait" class="btn btn-danger px-4">
                                            <i class="bi bi-arrow-down-circle me-1"></i> Retirer
                                        </button>
                                        <button type="submit" name="action" value="ajout" class="btn btn-success px-4">
                                            <i class="bi bi-arrow-up-circle me-1"></i> Ajouter
                                        </button>
                                      </div>
                                  </form>
                                </div>
                              </div>
                            </div>
                            {# --- FIN MODALE --- #}
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a href="{{ path('app_stock_show', {'id': stock.id}) }}" class="btn btn-sm btn-light border" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-sm btn-light border text-warning" title="Modifier">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-box-seam display-4 d-block mb-3"></i>
                            Aucun stock enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{# 3. ON INITIALISE DATATABLES #}
{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#table-stocks').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json"
                },
                // On empêche le tri sur la dernière colonne "Actions" (index 3) car ça n'a pas de sens
                "columnDefs": [
                    { "orderable": false, "targets": 3 }
                ],
                "pageLength": 10,
                "responsive": true,
                "searchDelay": 500 // L'astuce pro pour ne pas faire ramer le navigateur !
            });
        });
    </script>
{% endblock %}