{% extends 'base.html.twig' %}

{% block title %}État des Stocks{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-0">🏭 État du Stock</h1>
            <p class="text-muted">Suivi des quantités et des emplacements en temps réel.</p>
        </div>
        <a href="{{ path('app_stock_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Ajouter du Stock
        </a>
    </div>

    {# Messages flash de confirmation #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show shadow-sm border-0" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold text-muted">
                    <tr>
                        <th class="ps-4 py-3">Produit & Référence</th>
                        <th class="py-3 text-center">Emplacement</th>
                        <th class="py-3 text-center" style="width: 200px;">Quantité (Contrôle)</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stock in stocks %}
                    {% set estCritique = stock.quantite <= stock.produit.seuilAlerte %}
                    <tr class="{{ estCritique ? 'table-warning' : '' }}">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div>
                                    <div class="fw-bold text-dark">{{ stock.produit.nom }}</div>
                                    <small class="text-primary font-monospace">{{ stock.produit.reference }}</small>
                                </div>
                                {% if estCritique %}
                                    <span class="badge bg-danger ms-3 pulse-animation">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> STOCK BAS
                                    </span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border px-3 py-2">
                                <i class="bi bi-geo-alt-fill text-secondary me-1"></i>{{ stock.emplacement }}
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_stock_mouvement', {'id': stock.id, 'sens': 'moins'}) }}" 
                                   class="btn btn-sm btn-outline-danger px-3 fw-bold">-</a>
                                
                                <button type="button" class="btn btn-sm btn-white disabled fw-bold text-dark" style="min-width: 50px; background: white;">
                                    {{ stock.quantite }}
                                </button>

                                <a href="{{ path('app_stock_mouvement', {'id': stock.id, 'sens': 'plus'}) }}" 
                                   class="btn btn-sm btn-outline-success px-3 fw-bold">+</a>
                            </div>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a href="{{ path('app_stock_show', {'id': stock.id}) }}" class="btn btn-sm btn-light border" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-sm btn-light border text-warning" title="Modifier">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-box-seam display-4 d-block mb-3"></i>
                            Aucun stock enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}