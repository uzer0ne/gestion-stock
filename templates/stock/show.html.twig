{% extends 'base.html.twig' %}

{% block title %}Détails Stock #{{ stock.id }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="{{ path('app_stock_index') }}" class="btn btn-light border shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i>Retour
                </a>
                <div class="d-flex gap-2">
                    <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-warning shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i>Modifier
                    </a>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-header bg-dark py-3">
                    <h5 class="card-title mb-0 text-white fw-bold">
                        <i class="bi bi-info-circle me-2 text-primary"></i>Fiche d'emplacement
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Produit concerné</label>
                            <h3 class="fw-bold mb-0 text-dark">{{ stock.produit.nom }}</h3>
                            <p class="text-primary font-monospace mb-0">{{ stock.produit.reference }}</p>
                        </div>
                        <div class="col-md-3 text-center border-start border-end">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Quantité</label>
                            <span class="display-5 fw-bold {{ stock.quantite <= stock.produit.seuilAlerte ? 'text-danger' : 'text-success' }}">
                                {{ stock.quantite }}
                            </span>
                        </div>
                        <div class="col-md-3 text-center">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Zone</label>
                            <span class="badge bg-secondary fs-6">{{ stock.emplacement }}</span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 p-4">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted italic">ID Stock unique : <strong>#{{ stock.id }}</strong></span>
                        {{ include('stock/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}